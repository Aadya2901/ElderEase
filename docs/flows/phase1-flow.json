    {
        "id": "ac16a95c0191e0ec",
        "type": "function",
        "z": "6ac9e94bf2b7e02d",
        "name": "Risk Score Module",
        "func": "let hr = msg.payload.heartRate;\nlet spo2 = msg.payload.spo2;\nlet temp = msg.payload.temperature;\n\nlet score = 0;\n\nif (hr > 110) score += 3;\nif (spo2 < 92) score += 4;\nif (temp > 38) score += 3;\n\nmsg.payload.riskScore = score;\n\n// Risk label\nif(score <= 3) msg.payload.riskLabel = \"NORMAL\";\nelse if(score <= 6) msg.payload.riskLabel = \"WARNING\";\nelse msg.payload.riskLabel = \"EMERGENCY\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
