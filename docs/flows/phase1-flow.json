    {
        "id": "05a9e02a94544865",
        "type": "function",
        "z": "6ac9e94bf2b7e02d",
        "name": "Health Insights Generator",
        "func": "let hr = msg.payload.heartRate;\nlet spo2 = msg.payload.spo2;\nlet temp = msg.payload.temperature;\n\nlet insights = [];\n\n// 🔴 Critical conditions\nif (spo2 < 90) {\n    insights.push(\"⚠ Low Oxygen Level → Check breathing immediately\");\n}\n\nif (hr > 110) {\n    insights.push(\"⚠ High Heart Rate → Ask patient to rest\");\n}\n\nif (temp > 38) {\n    insights.push(\"⚠ Fever Detected → Monitor temperature\");\n}\n\n// 🟡 Mild conditions\nif (hr >= 95 && hr <= 110) {\n    insights.push(\"⚠ Slightly Elevated HR → Possible stress/fatigue\");\n}\n\nif (spo2 >= 90 && spo2 < 94) {\n    insights.push(\"⚠ Oxygen slightly low → Monitor closely\");\n}\n\n// 🟢 Normal\nif (insights.length === 0) {\n    insights.push(\"✅ Patient Stable\");\n}\n\nmsg.payload.insights = insights.join(\"<br><br>\");\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1690,
