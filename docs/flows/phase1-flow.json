    {
        "id": "09e6dbad1fac0194",
        "type": "function",
        "z": "6ac9e94bf2b7e02d",
        "name": "Vital Simulation Module",
        "func": "let heartRate = Math.floor(Math.random() * 80) + 60;\nlet spo2 = Math.floor(Math.random() * 15) + 85;\nlet temperature = Number((Math.random() * 3 + 35).toFixed(1));\n\nmsg.payload = {\n    userId: \"ELD001\",\n    deviceId: \"SIM001\",\n    heartRate: heartRate,\n    spo2: spo2,\n    temperature: temperature,\n    timestamp: new Date().toISOString(),\n    systemVersion: \"v1.0\"\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 870,
        "y": 140,
        "wires": [
            [
                "b4007771f7285101"
            ]
        ]
    },
    {
        "id": "b4007771f7285101",
        "type": "function",
        "z": "6ac9e94bf2b7e02d",
        "name": "Validation Module",
        "func": "let hr = msg.payload.heartRate;\nlet spo2 = msg.payload.spo2;\nlet temp = msg.payload.temperature;\n\nlet valid = true;\nlet error = null;\n\n// Heart Rate range check\nif (hr < 40 || hr > 180) {\n    valid = false;\n    error = \"Heart Rate out of realistic range\";\n}\n\n// SpO2 range check\nif (spo2 < 70 || spo2 > 100) {\n    valid = false;\n    error = \"SpO2 out of realistic range\";\n}\n\n// Temperature range check\nif (temp < 34 || temp > 42) {\n    valid = false;\n    error = \"Temperature out of realistic range\";\n}\n\n// Append validation result\nmsg.payload.valid = valid;\nmsg.payload.error = error;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 220,
        "wires": [
            [
                "3dc5769301d026d1"
            ]
        ]
    },
    {
        "id": "3dc5769301d026d1",
        "type": "function",
        "z": "6ac9e94bf2b7e02d",
        "name": "Decision Engine Module",
        "func": "// Stop classification if data is invalid\nif (!msg.payload.valid) {\n    msg.payload.status = \"INVALID\";\n    msg.payload.riskLevel = 0;\n    return msg;\n}\n\nlet hr = msg.payload.heartRate;\nlet spo2 = msg.payload.spo2;\nlet temp = msg.payload.temperature;\n\nlet status = \"NORMAL\";\nlet riskLevel = 1;\n\nlet maxHR = flow.get(\"maxHR\") || 110;\nlet minSpO2 = flow.get(\"minSpO2\") || 90;\nlet maxTemp = flow.get(\"maxTemp\") || 38;\n\n// Emergency condition\nif (hr > maxHR || spo2 < minSpO2 || temp > maxTemp) {\n    status = \"EMERGENCY\";\n    riskLevel = 3;\n}\n\n// Warning condition\nelse if (\n    hr > 95 ||\n    spo2 < 94 ||\n    temp > 37.5\n) {\n    status = \"WARNING\";\n    riskLevel = 2;\n}\n\nmsg.payload.status = status;\nmsg.payload.riskLevel = riskLevel;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 770,
        "y": 280,
        "wires": [
            [
                "ac16a95c0191e0ec"
            ]
        ]
    },
