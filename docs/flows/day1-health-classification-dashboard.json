    {
        "id": "5e1e2be0e2461cc3",
        "type": "function",
        "z": "94c07a1968faae61",
        "name": "Monitoring and Metrics Module",
        "func": "// Get stored metrics from flow memory\nlet totalReadings = flow.get(\"totalReadings\") || 0;\nlet emergencyCount = flow.get(\"emergencyCount\") || 0;\nlet lastEmergencyTime = flow.get(\"lastEmergencyTime\") || null;\nlet history = flow.get(\"history\") || [];\n\n// Increase total readings count\ntotalReadings++;\n\n// Check if current reading is an emergency\nif (msg.payload.status === \"EMERGENCY\") {\n    emergencyCount++;\n    lastEmergencyTime = new Date().toISOString();\n}\n\n// Save current reading into history\nhistory.push({\n    heartRate: msg.payload.heartRate,\n    spo2: msg.payload.spo2,\n    temperature: msg.payload.temperature,\n    status: msg.payload.status,\n    time: new Date().toISOString()\n});\n\n// Keep only last 5 readings\nif (history.length > 5) {\n    history.shift();\n}\n\n// Save metrics back into flow memory\nflow.set(\"totalReadings\", totalReadings);\nflow.set(\"emergencyCount\", emergencyCount);\nflow.set(\"lastEmergencyTime\", lastEmergencyTime);\nflow.set(\"history\", history);\n\n// Attach metrics to message\nmsg.metrics = {\n    totalReadings: totalReadings,\n    emergencyCount: emergencyCount,\n    lastEmergencyTime: lastEmergencyTime,\n    history: history\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
